# 실제 배포 도메인. sitemap.xml, robots.txt, OpenGraph 이미지 URL 생성에 사용됩니다.
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Google Analytics 4 측정 ID (형식: G-XXXXXXXXXX). 설정하면 자동으로 GA4 스크립트가 삽입됩니다.
# 발급 방법: docs/deployment.md 참고
NEXT_PUBLIC_GA_ID=

# Google Search Console 소유권 확인용 HTML 태그 값 (meta 태그의 content 값만 입력).
# 발급 방법: docs/deployment.md 참고
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# 관리자 페이지의 "AI 초안 생성" 기능(5단계)에서 사용하는 AI Provider 선택.
# 현재는 "claude"만 구현되어 있습니다. 값을 비워두면 기본값(claude)이 사용됩니다.
AI_PROVIDER=claude

# Anthropic API 키. https://console.anthropic.com/settings/keys 에서 발급받아 입력하세요.
# 절대 코드에 직접 넣지 말고, 이 파일을 복사한 .env.local(git에 커밋되지 않음)에만 입력하세요.
ANTHROPIC_API_KEY=

# 사용할 Claude 모델. 비워두면 기본값이 사용됩니다.
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# 관리자 저장(6단계)이 글을 어디에 저장할지 선택합니다: "local"(기본값) 또는 "github".
# local: content/{category}/{slug}.mdx 로컬 파일에 직접 저장합니다.
# github: 아래 GITHUB_* 설정을 이용해 GitHub 저장소에 커밋으로 저장합니다.
CONTENT_REPOSITORY=local

# CONTENT_REPOSITORY=github 일 때만 필요합니다.
# GitHub Fine-grained personal access token — 저장할 저장소에 대한
# "Contents: Read and write" 권한이 있어야 합니다. https://github.com/settings/tokens
GITHUB_TOKEN=
# 저장소 소유자(사용자명 또는 조직명)
GITHUB_OWNER=
# 저장소 이름
GITHUB_REPO=
# 커밋을 남길 브랜치. 비워두면 "main"이 사용됩니다.
GITHUB_BRANCH=main
# 저장소 안에서 콘텐츠가 위치할 경로. 비워두면 "content"가 사용됩니다(로컬과 동일 구조).
GITHUB_CONTENT_PATH=content
